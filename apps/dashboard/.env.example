# Supabase — get these from your Supabase project dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key — server only, NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# GitHub OAuth App — create at https://github.com/settings/developers
# Set Homepage URL to your app URL and Authorization callback URL to:
# https://yourdomain.com/api/github/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=https://yourdomain.com/api/github/callback

# Upstash Redis — get from https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis-id.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Encryption key for GitHub access tokens — generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-random-32-char-minimum-secret-key
